public static Node KthNode(Node head,int k){
        if(head==null || k<=0){
            return null;
        }

        Node first=head;
        Node second =head;

        for(int i=0;i<k;i++){
            if(first==null){
                return null;
            }
            first=first.next;
        }

        while(first!=null){
            first=first.next;
            second=second.next;
        }
        return second;
    }
