18.Find pivot value from arr(leftSum==rightSum)
public static int pivoteValue(int[] arr){

        int totalSum=0;
        for(int i:arr){
            totalSum+=i;
        }
        int leftSum=0,rightSum=0;
        for(int i=0;i<arr.length;i++){
            rightSum=totalSum-leftSum-arr[i];

            if(leftSum==rightSum){
                return arr[i];
            }
            leftSum+=arr[i];
        }

        return -1;
    }

