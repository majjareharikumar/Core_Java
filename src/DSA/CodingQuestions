public static int[] leftroatate(int[] arr){
        int first=arr[0];
        for(int i=0;i<arr.length-1;i++){
            arr[i]=arr[i+1];
        }
        arr[arr.length-1]=first;
        return arr;
    }

2.Left rotate array by k places
public static int[] leftrotatebyk(int[] arr,int k){

        while (k>0){
            int first=arr[0];
            for(int i=0;i<arr.length-1;i++){
                arr[i]=arr[i+1];
            }
            arr[arr.length-1]=first;
            k--;
        }
        return arr;
    }

