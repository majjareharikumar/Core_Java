public static void main(String[] args) {
        int[] arr = {3, 2, 4, 5, 1, 6, 7, 4, 3,6};

        int largest = Integer.MIN_VALUE;
        int second = Integer.MIN_VALUE;

        for (int n : arr) {
            if (n > largest) {
                second = largest;
                largest = n;
            } else if (n > second && n != largest) {
                second = n;
            }
        }
