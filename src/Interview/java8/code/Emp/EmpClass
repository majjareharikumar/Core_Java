import java.util.*;
import java.util.stream.*;
class Employee{
    int id;
    String name;
    int age;
    String dept;
    Double sal;
    String gender;
    int doj;

    public Employee(int id,String name,int age,String dept,Double sal,String gender,int doj){
        this.id=id;
        this.name=name;
        this.age=age;
        this.dept=dept;
        this.sal=sal;
        this.gender=gender;
        this.doj=doj;
    }
    public int getId(){return id;}
    public String getName(){return name;}
    public int getAge(){return age;}
    public String getDept(){return dept;}
    public Double getSal(){return sal;}
    public String getGender(){return gender;}
    public int getDoj(){return doj;}
}

